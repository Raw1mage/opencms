  {
    "id": "SEQ-1",
    "title": "Orphan reclaim on user-msg arrival",
    "description": "User retypes after a stalled round; persistUserMessage detects orphan assistant row and finalizes it before persisting the new user msg.",
    "participants": [
      { "id": "caller", "name": "Session.chat / runloop caller", "kind": "component" },
      { "id": "persist", "name": "persistUserMessage (user-message-persist.ts)", "kind": "component" },
      { "id": "stream", "name": "MessageV2.stream", "kind": "component" },
      { "id": "session", "name": "Session (index.ts)", "kind": "component" },
      { "id": "events", "name": "RuntimeEventService", "kind": "component" },
      { "id": "plugin", "name": "Plugin runtime", "kind": "component" }
    ],
    "messages": [
      { "from": "caller", "to": "persist", "label": "persistUserMessage({ info: newUserMsg, parts, sessionID, ... })" },
      { "from": "persist", "to": "stream", "label": "(NEW) stream(sessionID) — take newest" },
      { "from": "stream", "to": "persist", "label": "{ info: A (assistant, time.completed=undefined, time.created=now-7000) }" },
      { "from": "persist", "to": "persist", "label": "(NEW) orphan predicate true (age>=5000ms)" },
      { "from": "persist", "to": "session", "label": "(NEW) updateMessage({ ...A, time.completed=now, finish='error', error.data.message='abandoned_orphan_round' })" },
      { "from": "persist", "to": "events", "label": "(NEW) append({ domain:'workflow', eventType:'session.orphan_assistant_reclaimed', payload:{ sessionID, reclaimedMessageID, ageMs, providerId, modelID, accountId } })" },
      { "from": "persist", "to": "plugin", "label": "(existing) trigger('chat.message', meta, { message:newUserMsg, parts })" },
      { "from": "persist", "to": "session", "label": "(existing) updateMessage(newUserMsg)" },
      { "from": "persist", "to": "session", "label": "(existing) pinExecutionIdentity (if newUserMsg.model)" },
      { "from": "persist", "to": "session", "label": "(existing) updatePart × parts.length" },
      { "from": "persist", "to": "caller", "label": "resolve" }
    ]
  },
  {
    "id": "SEQ-2",
    "title": "RebindEpoch unexpected-reset detection",
    "description": "Second daemon_start bump for a sessionID in the same process; everBumped retains S but registry entry is missing.",
    "participants": [
      { "id": "caller", "name": "prompt.ts:2778 lazy daemon_start bump", "kind": "component" },
      { "id": "rebind", "name": "RebindEpoch.bumpEpoch", "kind": "component" },
      { "id": "registry", "name": "registry Map<string, EpochEntry>", "kind": "component" },
      { "id": "everBumped", "name": "everBumped Set<string> (NEW)", "kind": "component" },
      { "id": "events", "name": "RuntimeEventService", "kind": "component" }
    ],
    "messages": [
      { "from": "caller", "to": "rebind", "label": "bumpEpoch({ sessionID:S, trigger:'daemon_start', reason:'first runLoop iteration after daemon start' })" },
      { "from": "rebind", "to": "registry", "label": "get(S) → undefined → create { epoch:0, windowBumps:[] }" },
      { "from": "rebind", "to": "everBumped", "label": "(NEW) has(S) → true" },
      { "from": "rebind", "to": "events", "label": "(NEW) appendEventSafe({ domain:'anomaly', eventType:'session.rebind_epoch_unexpected_reset', anomalyFlags:['rebind_epoch_reset'], payload:{ trigger, reason, sessionEntryMissing:true, everBumpedSize } })" },
      { "from": "rebind", "to": "registry", "label": "entry.epoch = 1; lastBumpAt=now; windowBumps.push(now)" },
      { "from": "rebind", "to": "everBumped", "label": "(NEW) add(S) — no-op (already present)" },
      { "from": "rebind", "to": "events", "label": "(existing) appendEventSafe({ domain:'workflow', eventType:'session.rebind', payload:{ trigger, previousEpoch:0, currentEpoch:1, reason } })" },
      { "from": "rebind", "to": "caller", "label": "{ status:'bumped', previousEpoch:0, currentEpoch:1, rateLimitReason:null }" }
    ]
  }
