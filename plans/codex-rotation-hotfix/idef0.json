      "title": "Detect Codex 5H Exhaustion Proactively",
      "description": "Extend the cockpit quota-fetch path so codex family hits the same wham/usage endpoint as openai, with backoff computation and passive fallback on fetch failure",
      "decomposition": null
    },
    {
      "id": "A2",
      "title": "Filter Rotation Candidate Pool By Codex Quota",
      "description": "Mark codex candidates isQuotaLimited when hourlyRemaining or weeklyRemaining is exhausted, mirroring the existing openai filter",
      "decomposition": null
    },
    {
      "id": "A3",
      "title": "Enforce Codex Family Only Fallback",
      "description": "When currentVector provider resolves to codex, drop non-codex candidates before scoring and surface CodexFamilyExhausted when pool is empty",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Classify Codex 5H Error Messages",
      "description": "Extend parseRateLimitReason in backoff.ts with codex-specific 5H / response_time_window / usage-limit pattern matches so the passive path still classifies correctly when cockpit misses",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Emit Observable Log Per Decision",
      "description": "One log line per new decision branch (cockpit decision, candidate skip, cross-provider reject, family exhaust) so operators can grep the daemon log and trace rotation behavior",
      "decomposition": null
    }
  ],
