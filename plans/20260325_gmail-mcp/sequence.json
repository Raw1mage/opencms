[
  {
    "diagram_title": "Gmail Tool Execution",
    "scenario": "AI session calls a Gmail tool (e.g., list-messages)",
    "moduleRef": "A2",
    "participants": [
      { "id": "P1", "name": "AI Session", "type": "actor", "componentRef": "SYS1" },
      { "id": "P2", "name": "MCP Tool Router", "type": "component", "componentRef": "C4" },
      { "id": "P3", "name": "GmailApp", "type": "component", "componentRef": "C2" },
      { "id": "P4", "name": "ManagedAppRegistry", "type": "component", "componentRef": "C3" },
      { "id": "P5", "name": "gauth.json", "type": "component", "componentRef": "C6" },
      { "id": "P6", "name": "GmailClient", "type": "component", "componentRef": "C1" },
      { "id": "P7", "name": "Gmail API", "type": "system", "componentRef": "SYS2" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "execute(gmail, list-messages, {query})", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P4", "label": "requireReady('gmail')", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P4", "to": "P2", "label": "ok", "type": "return", "order": 3 },
      { "id": "MSG4", "from": "P2", "to": "P3", "label": "execute('list-messages', args)", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P3", "to": "P5", "label": "readGAuthTokens()", "type": "sync", "order": 5 },
      { "id": "MSG6", "from": "P5", "to": "P3", "label": "{ access_token }", "type": "return", "order": 6 },
      { "id": "MSG7", "from": "P3", "to": "P6", "label": "listMessages(token, {query})", "type": "sync", "order": 7 },
      { "id": "MSG8", "from": "P6", "to": "P7", "label": "GET /users/me/messages?q=...", "type": "sync", "order": 8 },
      { "id": "MSG9", "from": "P7", "to": "P6", "label": "{ messages: [...] }", "type": "return", "order": 9 },
      { "id": "MSG10", "from": "P6", "to": "P3", "label": "MessageListEntry[]", "type": "return", "order": 10 },
      { "id": "MSG11", "from": "P3", "to": "P3", "label": "formatMessageList() → Markdown", "type": "sync", "order": 11 },
      { "id": "MSG12", "from": "P3", "to": "P2", "label": "Markdown string", "type": "return", "order": 12 },
      { "id": "MSG13", "from": "P2", "to": "P1", "label": "Tool result", "type": "return", "order": 13 }
    ],
    "fragments": [
      { "id": "FRAG1", "type": "alt", "label": "Token missing → throw UsageStateError", "messageRefs": ["MSG5", "MSG6"] }
    ]
  },
  {
    "diagram_title": "OAuth Connect (Generalized)",
    "scenario": "User initiates OAuth connect from Gmail app, scopes merged with Calendar",
    "moduleRef": "A5",
    "participants": [
      { "id": "P1", "name": "User Browser", "type": "actor", "componentRef": "SYS1" },
      { "id": "P2", "name": "OAuth Routes", "type": "component", "componentRef": "C5" },
      { "id": "P3", "name": "ManagedAppRegistry", "type": "component", "componentRef": "C3" },
      { "id": "P4", "name": "Google OAuth", "type": "system", "componentRef": "SYS2" },
      { "id": "P5", "name": "gauth.json", "type": "component", "componentRef": "C6" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "GET /apps/gmail/oauth/connect", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "Collect scopes from installed Google apps", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P2", "label": "Calendar scopes + Gmail scope", "type": "return", "order": 3 },
      { "id": "MSG4", "from": "P2", "to": "P1", "label": "302 Redirect to Google consent (merged scopes)", "type": "return", "order": 4 },
      { "id": "MSG5", "from": "P1", "to": "P4", "label": "User authorizes", "type": "sync", "order": 5 },
      { "id": "MSG6", "from": "P4", "to": "P2", "label": "GET /apps/gmail/oauth/callback?code=...", "type": "async", "order": 6 },
      { "id": "MSG7", "from": "P2", "to": "P4", "label": "POST /token (exchange code)", "type": "sync", "order": 7 },
      { "id": "MSG8", "from": "P4", "to": "P2", "label": "{ access_token, refresh_token }", "type": "return", "order": 8 },
      { "id": "MSG9", "from": "P2", "to": "P5", "label": "Write tokens to gauth.json", "type": "sync", "order": 9 },
      { "id": "MSG10", "from": "P2", "to": "P3", "label": "setConfigKeys('gmail', ['googleOAuth'])", "type": "sync", "order": 10 },
      { "id": "MSG11", "from": "P2", "to": "P3", "label": "setConfigKeys('google-calendar', ['googleOAuth'])", "type": "sync", "order": 11 },
      { "id": "MSG12", "from": "P2", "to": "P3", "label": "enable('gmail') + enable('google-calendar')", "type": "sync", "order": 12 },
      { "id": "MSG13", "from": "P2", "to": "P1", "label": "HTML success page (auto-close)", "type": "return", "order": 13 }
    ],
    "fragments": [
      { "id": "FRAG1", "type": "opt", "label": "google-calendar not installed → skip MSG11/MSG12 for calendar", "messageRefs": ["MSG11"] }
    ]
  }
]
