[
  {
    "id": "P1",
    "title": "Happy path: turn N+1 hits prefix cache against turn N",
    "description": "Steady-state codex session, second user message, delta=true with previous_response_id; expect cached_tokens >= 90% input_tokens",
    "participants": [
      { "id": "Caller", "label": "Session.runStep" },
      { "id": "Assembler", "componentRef": "C1.1", "label": "PromptAssembler" },
      { "id": "Registry", "componentRef": "C1.2", "label": "FragmentRegistry" },
      { "id": "Bundle", "componentRef": "C1.3", "label": "BundleAssembler" },
      { "id": "Persona", "componentRef": "C1.4", "label": "PersonaRouter" },
      { "id": "Convert", "componentRef": "C2.1", "label": "convertPrompt" },
      { "id": "Build", "componentRef": "C2.2", "label": "buildResponsesApiRequest" },
      { "id": "WS", "componentRef": "C2.3", "label": "WS Transport" },
      { "id": "Cache", "componentRef": "C3.1", "label": "Prefix Cache" },
      { "id": "Chain", "componentRef": "C3.2", "label": "Chain State" }
    ],
    "messages": [
      { "id": "MSG1", "from": "Caller", "to": "Assembler", "label": "stream(prompt, model)" },
      { "id": "MSG2", "from": "Assembler", "to": "Persona", "label": "provider(model)" },
      { "id": "MSG3", "from": "Persona", "to": "Assembler", "label": "driverText (= upstream default.md or model-specific)" },
      { "id": "MSG4", "from": "Assembler", "to": "Registry", "label": "collectFragments(session, agent, skills, mcp)" },
      { "id": "MSG5", "from": "Registry", "to": "Assembler", "label": "ContextFragment[]" },
      { "id": "MSG6", "from": "Assembler", "to": "Bundle", "label": "assemble(fragments)" },
      { "id": "MSG7", "from": "Bundle", "to": "Assembler", "label": "{ developerItem, userItem }" },
      { "id": "MSG8", "from": "Assembler", "to": "Convert", "label": "streamText with system=driverText, messages=[devItem, userItem, ...history]" },
      { "id": "MSG9", "from": "Convert", "to": "Build", "label": "{ instructions: driverText, input: [devItem, userItem, ...] }" },
      { "id": "MSG10", "from": "Build", "to": "WS", "label": "request body with prompt_cache_key=sessionId, previous_response_id=<prev>" },
      { "id": "MSG11", "from": "WS", "to": "Chain", "label": "delta=true with new items only" },
      { "id": "MSG12", "from": "Chain", "to": "Cache", "label": "reconstructed prompt for cache lookup" },
      { "id": "MSG13", "from": "Cache", "to": "WS", "label": "usage.cached_tokens >= 90% input_tokens" },
      { "id": "MSG14", "from": "WS", "to": "Caller", "label": "stream completes; usage logged" }
    ]
  },
  {
    "id": "P2",
    "title": "Account rotation does not bust cache key",
    "description": "Same session rotates from account X to account Y mid-turn; prompt_cache_key stays equal to sessionId, cache namespace continuous",
    "participants": [
      { "id": "Caller", "label": "Session.runStep (autonomous resume)" },
      { "id": "Provider", "componentRef": "C2.2", "label": "buildResponsesApiRequest" },
      { "id": "WS_X", "label": "WS Transport (account X)" },
      { "id": "WS_Y", "label": "WS Transport (account Y, post-swap)" },
      { "id": "Cache", "componentRef": "C3.1", "label": "Prefix Cache (per cache_key)" }
    ],
    "messages": [
      { "id": "MSG1", "from": "Caller", "to": "Provider", "label": "build with accountId=X" },
      { "id": "MSG2", "from": "Provider", "to": "WS_X", "label": "prompt_cache_key=sessionId (NOT codex-X-sessionId)" },
      { "id": "MSG3", "from": "WS_X", "to": "Cache", "label": "first call under cache_key=sessionId" },
      { "id": "MSG4", "from": "Cache", "to": "WS_X", "label": "establishes cache prefix" },
      { "id": "MSG5", "from": "Caller", "to": "Provider", "label": "next call with accountId=Y after rotation" },
      { "id": "MSG6", "from": "Provider", "to": "WS_Y", "label": "prompt_cache_key=sessionId (still — DD-6)" },
      { "id": "MSG7", "from": "WS_Y", "to": "Cache", "label": "lookup against same cache_key" },
      { "id": "MSG8", "from": "Cache", "to": "WS_Y", "label": "cache hit (same prefix)" }
    ]
  },
  {
    "id": "P3",
    "title": "Daemon upgrade triggers chain reset",
    "description": "Old daemon ran legacy wire (instructions=monolithic). After upgrade, new daemon emits instructions=driver only. Server-side previous_response_id state is incompatible — force chain reset.",
    "participants": [
      { "id": "Bootstrap", "label": "daemon startup" },
      { "id": "Continuation", "componentRef": "C2.3", "label": "ContinuationStore" },
      { "id": "WS", "componentRef": "C2.3", "label": "WS Transport" },
      { "id": "Server", "componentRef": "C3.2", "label": "Chain State" }
    ],
    "messages": [
      { "id": "MSG1", "from": "Bootstrap", "to": "Continuation", "label": "detect legacy wire schema marker" },
      { "id": "MSG2", "from": "Continuation", "to": "WS", "label": "broadcast resetWsSession(sessionId) for each active codex session" },
      { "id": "MSG3", "from": "WS", "to": "Server", "label": "next request: previous_response_id omitted, full input[]" },
      { "id": "MSG4", "from": "Server", "to": "WS", "label": "fresh response_id; chain re-established" }
    ]
  }
]
