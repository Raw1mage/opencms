{
  "$schema": "https://opencode.ai/config.json",
  // "plugin": ["opencode-openai-codex-auth"],
  // "enterprise": {
  //   "url": "https://enterprise.dev.opencode.ai",
  // },
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    // Enable beta-tool when this project wants local worktree orchestration.
    // In a source checkout, opencode normalizes this internal MCP to the repo entrypoint.
    "beta-tool": {
      "type": "local",
      "command": ["bun", "packages/mcp/branch-cicd/src/index.ts"],
      "enabled": false,
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
