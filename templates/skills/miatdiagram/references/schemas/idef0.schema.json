{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "miatdiagram/idef0.schema.json",
  "title": "IDEF0 Descriptor",
  "type": "object",
  "required": ["diagram_title", "node_reference", "activities", "arrows"],
  "properties": {
    "diagram_title": { "type": "string", "minLength": 1 },
    "node_reference": { "type": "string", "pattern": "^A[0-9]+$" },
    "activities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string", "pattern": "^A[0-9]+$" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "decomposition": { "type": ["object", "null"] }
        },
        "additionalProperties": true
      }
    },
    "arrows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "target", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["input", "control", "output", "mechanism", "call"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
