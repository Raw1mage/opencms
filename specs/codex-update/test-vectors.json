      "buildHeadersOptions": {
        "accessToken": "eyJ-fake"
      }
    },
    "expected": {
      "headers-absent": [
        "session_id",
        "thread_id"
      ]
    },
    "test-file": "headers.test.ts",
    "test-name": "omits both session_id and thread_id when neither provided"
  },
  {
