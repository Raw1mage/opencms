[
  {
    "id": "TV-1",
    "requirement": "Distinct session_id and thread_id headers",
    "scenario": "caller supplies only sessionId",
    "input": {
      "buildHeadersOptions": {
        "accessToken": "eyJ-fake",
        "sessionId": "S-uuid-aaaa"
      }
    },
    "expected": {
      "headers": {
        "session_id": "S-uuid-aaaa",
        "thread_id": "S-uuid-aaaa"
      }
    },
    "test-file": "headers.test.ts",
    "test-name": "emits both session_id and thread_id with default-equality when only sessionId provided"
  },
  {
    "id": "TV-2",
    "requirement": "Distinct session_id and thread_id headers",
    "scenario": "caller supplies both",
    "input": {
      "buildHeadersOptions": {
        "accessToken": "eyJ-fake",
        "sessionId": "S-uuid-aaaa",
        "threadId": "T-uuid-bbbb"
      }
    },
    "expected": {
      "headers": {
        "session_id": "S-uuid-aaaa",
        "thread_id": "T-uuid-bbbb"
      }
    },
    "test-file": "headers.test.ts",
    "test-name": "emits distinct session_id and thread_id when both provided"
  },
  {
    "id": "TV-3",
    "requirement": "Distinct session_id and thread_id headers",
    "scenario": "neither provided",
