{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "grafcet-renderer-overhaul layout model",
  "description": "Internal types produced by L1, consumed by L3/L4/L5/L6.",
  "definitions": {
    "Point": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": {"type": "number"},
        "y": {"type": "number"}
      }
    },
    "Bounds": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {"type": "number"},
        "y": {"type": "number"},
        "width": {"type": "number", "minimum": 0},
        "height": {"type": "number", "minimum": 0}
      }
    },
    "ExitDir": {
      "type": "string",
      "enum": ["N", "S", "E", "W"]
    },
    "Port": {
      "type": "object",
      "required": ["id", "point", "exit_dir", "kind"],
      "properties": {
        "id": {"type": "string"},
        "point": {"$ref": "#/definitions/Point"},
        "exit_dir": {"$ref": "#/definitions/ExitDir"},
        "kind": {"type": "string", "enum": ["step_input", "step_output", "gate_input", "gate_output", "branch_anchor"]},
        "owner_id": {"type": "string"},
        "transition_id": {"type": "string"}
      }
    },
    "BranchAnchor": {
      "type": "object",
      "required": ["id", "step_id", "point"],
      "properties": {
        "id": {"type": "string", "pattern": "^branch_anchor:"},
        "step_id": {"type": "string"},
        "point": {"$ref": "#/definitions/Point"}
      }
    },
    "GateType": {
      "type": "string",
      "enum": ["track", "or_diverge", "or_converge", "and_diverge", "and_converge"]
    },
    "Gate": {
      "type": "object",
      "required": ["id", "gate_type", "bounds", "input_ports", "output_ports", "source_ids", "target_ids"],
      "properties": {
        "id": {"type": "string"},
        "gate_type": {"$ref": "#/definitions/GateType"},
        "bounds": {"$ref": "#/definitions/Bounds"},
        "input_ports": {"type": "array", "items": {"$ref": "#/definitions/Port"}},
        "output_ports": {"type": "array", "items": {"$ref": "#/definitions/Port"}},
        "source_ids": {"type": "array", "items": {"type": "string"}},
        "target_ids": {"type": "array", "items": {"type": "string"}},
        "condition": {"type": "string"},
        "port_labels": {"type": "array", "items": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "string"}}},
        "is_simplified_to_dot": {"type": "boolean"}
      },
      "allOf": [
        {
          "description": "R-4: no 1-in-1-out gate symbols",
          "not": {
            "properties": {
              "source_ids": {"maxItems": 1, "minItems": 1},
              "target_ids": {"maxItems": 1, "minItems": 1},
              "gate_type": {"enum": ["or_diverge", "or_converge", "and_diverge", "and_converge"]}
            }
          }
        },
        {
          "description": "R-5: no M-in-N-out illegal gates (M>1 AND N>1)",
          "not": {
            "properties": {
              "source_ids": {"minItems": 2},
              "target_ids": {"minItems": 2}
            }
          }
        }
      ]
    },
    "Edge": {
      "type": "object",
      "required": ["id", "from_port", "to_port", "route_points"],
      "properties": {
        "id": {"type": "string"},
        "from_port": {"type": "string"},
        "to_port": {"type": "string"},
        "route_points": {
          "type": "array",
          "minItems": 2,
          "items": {"$ref": "#/definitions/Point"}
        },
        "semantic_type": {"type": "string"}
      }
    },
    "ConditionStub": {
      "type": "object",
      "required": ["id", "center", "label"],
      "properties": {
        "id": {"type": "string"},
        "center": {"$ref": "#/definitions/Point"},
        "label": {"type": "string"},
        "lane_x": {"type": "number"},
        "anchor_side": {"type": "string", "enum": ["left", "right"]}
      }
    },
    "Violation": {
      "type": "object",
      "required": ["type", "severity", "target_ids", "message"],
      "properties": {
        "type": {"type": "string"},
        "severity": {"type": "string", "enum": ["info", "warning", "error"]},
        "target_ids": {"type": "array", "items": {"type": "string"}},
        "message": {"type": "string"},
        "pre_existing": {"type": "boolean"},
        "originating_layer": {"type": "string", "enum": ["L1", "L2", "L3", "L4", "L5", "L6"]}
      }
    },
    "TraceEvent": {
      "type": "object",
      "required": ["layer", "subject_id", "operation"],
      "properties": {
        "layer": {"type": "string", "enum": ["L1", "L2", "L3", "L4", "L5", "L6"]},
        "subject_id": {"type": "string"},
        "operation": {"type": "string"},
        "details": {"type": "object"}
      }
    },
    "LayoutModel": {
      "type": "object",
      "required": ["semantic_graph", "step_boxes", "gates", "edges", "violations"],
      "properties": {
        "semantic_graph": {"type": "object"},
        "step_boxes": {"type": "array"},
        "action_boxes": {"type": "array"},
        "gates": {"type": "array", "items": {"$ref": "#/definitions/Gate"}},
        "branch_anchors": {"type": "array", "items": {"$ref": "#/definitions/BranchAnchor"}},
        "edges": {"type": "array", "items": {"$ref": "#/definitions/Edge"}},
        "condition_stubs": {"type": "array", "items": {"$ref": "#/definitions/ConditionStub"}},
        "violations": {"type": "array", "items": {"$ref": "#/definitions/Violation"}},
        "trace_events": {"type": "array", "items": {"$ref": "#/definitions/TraceEvent"}},
        "simplified_gate_ids": {"type": "array", "items": {"type": "string"}, "description": "Set populated by L1 per DD-4"}
      }
    }
  },
  "$ref": "#/definitions/LayoutModel"
}
