  {
    "id": "TV-1",
    "scenario": "Account switch on codex session — happy path",
    "given": {
      "session": "ses_test_codex_1",
      "providerId": "codex",
      "previousAccountId": "A1",
      "accountId": "A2",
      "lastMessages": [
        { "type": "tool", "tool": "apply_patch", "callID": "call_p1", "status": "completed", "outputBrief": "✓ Success: foo.md" },
        { "type": "tool", "tool": "apply_patch", "callID": "call_p2", "status": "completed", "outputBrief": "✓ Success: bar.md" },
        { "type": "tool", "tool": "read", "callID": "call_r1", "status": "completed" }
      ]
    },
    "when": "Continuation.run({ kind: 'account_switch', sessionID: 'ses_test_codex_1', previousAccountId: 'A1', accountId: 'A2', providerId: 'codex' })",
    "then": {
      "classifierDecision": {
        "breaksChain": true,
        "capturesDigest": true,
        "recomputesChainStable": true,
        "injectsChainInit": true,
        "injectsAmnesia": false,
        "bumpsRebindEpoch": true
      },
      "digestEntries": [
        { "call_id": "call_p1", "tool": "apply_patch", "status": "completed" },
        { "call_id": "call_p2", "tool": "apply_patch", "status": "completed" }
      ],
      "digestExcludes": ["call_r1"],
      "invalidateContinuationFamilyCalled": true,
      "invalidateOrderingInvariant": "digest captured before invalidate (DD-8)",
      "pendingInjection": { "chainInit": true, "amnesia": false, "reason": "account_switch" },
      "rebindEpochBumped": true,
      "sessionRebindPayload": { "chainBreakClass": "SS-break" },
      "runtimeEvents": ["chain.commitment.captured", "chain.init.injected"]
    }
  },
