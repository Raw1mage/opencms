[
  {
    "id": "TV-1",
    "requirement": "idle watchdog must not kill an interactive tool awaiting human input",
    "scenario": "user takes longer than 90s to answer",
    "given": { "watchdogTimeoutMs": 90000, "questionPending": true, "chunksFlowing": false, "pauseCalled": true },
    "when": "elapsedMs = 95000",
    "then": { "aborted": false, "questionStillPending": true }
  },
  {
    "id": "TV-2",
    "requirement": "genuine user/session abort still interrupts a pending question",
    "scenario": "input.abort fires during pending question",
    "given": { "questionPending": true, "pauseCalled": true },
    "when": "input.abort fires (reason=manual-stop)",
    "then": { "rejected": true, "errorName": "QuestionRejectedError" }
  },
  {
    "id": "TV-3",
    "requirement": "0-byte wedge detection preserved + resume re-arms",
    "scenario": "after resume, a genuine wedge still fires watchdog",
    "given": { "pauseCalled": true, "resumeCalled": true, "chunksFlowing": false },
    "when": "elapsedMs after resume = 90001",
    "then": { "aborted": true, "abortReasonIncludes": "stream idle timeout" }
  },
  {
    "id": "TV-4",
    "requirement": "pause/resume idempotency",
    "scenario": "resume called twice",
    "given": { "pauseCalled": true },
    "when": "resume() then resume() again",
    "then": { "throws": false, "watchdogArmed": true }
  }
]
