{
  "diagram_title": "Compact Session 上下文",
  "node_reference": "A0",
  "description": "Reduce Session's effective 訊息-串流 size before 下一個 LLM 呼叫, using cheapest available kind that fits constraints.",
  "icoms": {
    "inputs": [
      "session.id",
      "current message stream",
      "current Memory state",
      "session.execution (pinned identity)",
      "lastFinished assistant tokens"
    ],
    "controls": [
      "AGENTS.md rule 1 (no silent fallback)",
      "DD-1 state-driven discipline",
      "DD-9 single entry-point signature",
      "model.limit.context budget"
    ],
    "outputs": [
      "new Anchor in message stream",
      "updated Memory.lastCompactedAt",
      "optional synthetic Continue user message",
      "log lines for kind transitions"
    ],
    "mechanisms": [
      "C4 SessionCompaction.run",
      "C1 Memory module",
      "Storage backend",
      "Plugin.trigger session.compact hook (codex/openai)",
      "SessionProcessor (LLM agent path)"
    ]
  },
  "activities": [
    {
      "id": "A1",
      "name": "Evaluate compaction need (state-driven)",
      "parent": "A0",
      "description": "Each runloop iteration reads observable 狀態 與 返回 Optional<Observed>. Sets 無 flags. DD-1.",
      "icoms": {
        "inputs": [
          "session state snapshot",
          "most-recent Anchor"
        ],
        "controls": [
          "DD-1 state-driven",
          "Cooldown threshold"
        ],
        "outputs": [
          "Observed enum value or null"
        ],
        "mechanisms": [
          "C10 deriveObservedCondition"
        ]
      }
    },
    {
      "id": "A2",
      "name": "Maintain Memory",
      "parent": "A0",
      "description": "依-Session persistent memory artifact. Primary content 回合summary; auxiliary 檔案/action metadata.",
      "icoms": {
        "inputs": [
          "runloop exit signal",
          "tool invocation parts"
        ],
        "controls": [
          "DD-2 capture timing",
          "DD-3 migration",
          "rawTailBudget"
        ],
        "outputs": [
          "SessionMemory persisted to Storage",
          "render outputs (LLM/Human)"
        ],
        "mechanisms": [
          "C1 Memory module"
        ]
      }
    },
    {
      "id": "A21",
      "name": "Capture TurnSummary at runloop exit",
      "parent": "A2",
      "description": "DD-2: 僅 於 runloop exit, 不 mid-執行. last助手 final 文字 appended 到 Memory.回合summaries.",
      "icoms": {
        "inputs": [
          "lastAssistant.finish ≠ tool-calls",
          "lastAssistant final text part"
        ],
        "controls": [
          "DD-2"
        ],
        "outputs": [
          "new TurnSummary entry"
        ],
        "mechanisms": [
          "C11 TurnSummary capture"
        ]
      }
    },
    {
      "id": "A22",
      "name": "Track file/action auxiliary metadata",
      "parent": "A2",
      "description": "Legacy shared上下文 role retained 作為 auxiliary. 不 primary memory content.",
      "icoms": {
        "inputs": [
          "completed tool parts each turn"
        ],
        "controls": [],
        "outputs": [
          "fileIndex[] entries",
          "actionLog[] entries"
        ],
        "mechanisms": [
          "C1 Memory module"
        ]
      }
    },
    {
      "id": "A23",
      "name": "Render Memory for consumer",
      "parent": "A2",
      "description": "Two independent functions 依 DD-5.",
      "icoms": {
        "inputs": [
          "SessionMemory state"
        ],
        "controls": [
          "DD-5"
        ],
        "outputs": [
          "renderForLLM string (compact, provider-agnostic)",
          "renderForHuman string (timeline)"
        ],
        "mechanisms": [
          "C1 Memory module"
        ]
      }
    },
    {
      "id": "A24",
      "name": "Persist Memory + read with legacy fallback",
      "parent": "A2",
      "description": "DD-3: write 僅 到 new 路徑; read 使用 fallback 到 shared上下文 + checkpoint if new 路徑 empty.",
      "icoms": {
        "inputs": [
          "SessionMemory in-memory state"
        ],
        "controls": [
          "DD-3"
        ],
        "outputs": [
          "Storage write",
          "legacy fallback read"
        ],
        "mechanisms": [
          "Storage backend"
        ]
      }
    },
    {
      "id": "A3",
      "name": "Throttle (Cooldown)",
      "parent": "A0",
      "description": "Prevent repeated 壓縮 within window. Reads Memory.lastcompacted於; 無 separate 狀態. DD-7.",
      "icoms": {
        "inputs": [
          "Memory.lastCompactedAt",
          "currentRound",
          "threshold"
        ],
        "controls": [
          "DD-7"
        ],
        "outputs": [
          "throttled boolean"
        ],
        "mechanisms": [
          "C3 Cooldown helper (lives in memory.ts)"
        ]
      }
    },
    {
      "id": "A4",
      "name": "Execute compaction kind",
      "parent": "A0",
      "description": "Walk KIND CHAIN 表 indexed 由 observed; first kind that succeeds writes Anchor.",
      "icoms": {
        "inputs": [
          "RunInput",
          "KIND_CHAIN[observed]",
          "INJECT_CONTINUE[observed]"
        ],
        "controls": [
          "AGENTS.md rule 1",
          "DD-9",
          "R-2 cost-monotonic"
        ],
        "outputs": [
          "new Anchor",
          "optional synthetic Continue",
          "kind-transition logs"
        ],
        "mechanisms": [
          "C5..C9 executors"
        ]
      }
    },
    {
      "id": "A41",
      "name": "Free narrative",
      "parent": "A4",
      "description": "Use Memory.渲染供LLM 作為 Anchor body. Zero API. C5.",
      "icoms": {
        "inputs": [
          "Memory.renderForLLM(sid)"
        ],
        "controls": [
          "budget: ≤ 30% model.limit.context"
        ],
        "outputs": [
          "Anchor with kind='narrative'"
        ],
        "mechanisms": [
          "C5 Narrative executor"
        ]
      }
    },
    {
      "id": "A42",
      "name": "Free schema",
      "parent": "A4",
      "description": "Legacy shared上下文.snapshot 輸出. Zero API. Used 僅 when narrative empty. C6.",
      "icoms": {
        "inputs": [
          "SharedContext.snapshot output"
        ],
        "controls": [],
        "outputs": [
          "Anchor with kind='schema'"
        ],
        "mechanisms": [
          "C6 Schema executor"
        ]
      }
    },
    {
      "id": "A43",
      "name": "Free replay-tail",
      "parent": "A4",
      "description": "Last N raw rounds serialized 作為 plain 文字. Zero API. C7.",
      "icoms": {
        "inputs": [
          "message-stream tail (last N rounds)"
        ],
        "controls": [
          "rawTailBudget"
        ],
        "outputs": [
          "Anchor with kind='replay-tail'"
        ],
        "mechanisms": [
          "C7 Replay-tail executor"
        ]
      }
    },
    {
      "id": "A44",
      "name": "Low-cost server-side",
      "parent": "A4",
      "description": "Plugin.trigger Session.compact (codex/openai /responses/compact). Cheaper than full LLM round but counts toward 5h burst. C8.",
      "icoms": {
        "inputs": [
          "conversation items built from message stream",
          "agent prompt"
        ],
        "controls": [
          "provider supports session.compact hook",
          "observed admits paid kinds"
        ],
        "outputs": [
          "Anchor with kind='low-cost-server'",
          "compactedItems opaque payload"
        ],
        "mechanisms": [
          "Plugin.trigger session.compact"
        ]
      }
    },
    {
      "id": "A45",
      "name": "LLM agent",
      "parent": "A4",
      "description": "Full LLM round 使用 custom 壓縮 提示. Most expensive; final fallback. C9.",
      "icoms": {
        "inputs": [
          "full conversation history",
          "compaction agent prompt template"
        ],
        "controls": [
          "observed admits paid kinds"
        ],
        "outputs": [
          "Anchor with kind='llm-agent'"
        ],
        "mechanisms": [
          "SessionProcessor",
          "compaction agent"
        ]
      }
    }
  ],
  "removed_activities": [
    {
      "id": "X-A-Schedule",
      "name": "Schedule next-round compaction",
      "reason": "DD-1 — replaced by A1 state-driven evaluation"
    },
    {
      "id": "X-A-PendingFlag",
      "name": "Mark pending rebind compaction",
      "reason": "DD-1 — flag deleted; processor.ts only updates pinned identity"
    }
  ]
}
