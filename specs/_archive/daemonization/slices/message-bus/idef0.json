{
  "diagram_title": "Operate Unified 訊息 Bus",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "發布 事件 到 Topic",
      "description": "Validate 事件 props against zod schema 與 派發 到 all topic subscribers. 項目 point 供 124 Bus.發布 sites + 318 debugCheckpoint sites 透過 Bus.debug wrapper.",
      "decomposition": "A1"
    },
    {
      "id": "A2",
      "title": "路由 到 後端 Subscribers",
      "description": "Execute 已註冊 後端 subscriber callbacks: debug-writer (debug.記錄), tui-toaster (TUI toast). Each subscriber applies its own 記錄level gate.",
      "decomposition": "A2"
    },
    {
      "id": "A3",
      "title": "Transport 到 前端 透過 SSE",
      "description": "全域bus SSE transport adapter — wildcard subscriber that relays all 事件 到 前端 透過 Hono 串流SSE endpoint /api/v2/全域/事件.",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "路由 前端 事件 到 Components",
      "description": "Broadcast-first delivery 到 all children stores. 前端 subscribers (webapp toaster, LLM card, Session 清單) process 事件 透過 事件-reducer.",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Migrate Legacy 事件 Callers",
      "description": "Backward-compatible wrappers: debugCheckpoint() → Bus.debug(), 全域bus.emit() → Bus.publish(), tui事件.ToastShow → tui-toaster subscriber.",
      "decomposition": null
    }
  ],
