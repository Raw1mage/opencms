{
  "diagram_title": "Session Poll Defence Layer",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "Serve Cached Session Read",
      "description": "返回 Session metadata 與 訊息 清單 來自 在-process 快取 when fresh; 在 miss, load 來自 儲存 與 memoize.",
      "decomposition": null
    },
    {
      "id": "A2",
      "title": "Invalidate 快取 在 Write 事件",
      "description": "Subscribe 到 訊息v2.事件.* 與 Session.事件.* (including worker-bridged 事件) 與 drop all 快取 keys 供 affected SessionID; bump 依-Session version counter.",
      "decomposition": null
    },
    {
      "id": "A3",
      "title": "Evaluate Conditional GET",
      "description": "Compute weak ETag 來自 SessionID + version; compare If-None-比對 header; short-circuit 使用 304 when matching.",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Enforce 依-身分 Rate Limit",
      "description": "Apply token-bucket 依 (username, method, 路由pattern); 返回 429 使用 重試-After when exhausted; exempt internal 與 健康 路徑.",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Expose 快取 與 RateLimit 健康",
      "description": "Serve GET /api/v2/伺服器/快取/健康 使用 entries, hit/miss rate, eviction count, subscriptionAlive, 與 rate-limit stats over past 5 minutes.",
      "decomposition": null
    },
    {
      "id": "A6",
      "title": "Load Tunables 來自 tweaks.cfg",
      "description": "解析 /etc/opencode/tweaks.cfg 使用 defaults; 記錄 actual effective values 於 startup; warn (不 silently fall 回到) 在 format 錯誤.",
      "decomposition": null
    }
  ],
  "arrows": [
