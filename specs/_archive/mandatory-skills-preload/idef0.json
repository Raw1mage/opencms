{
  "diagram_title": "必要-技能-預載 — Runtime 預載 與 釘選 Pipeline",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "解析 必要 清單",
      "description": "根據目前 agent 識別（Main vs coding subagent）讀入對應宣告檔（AGENTS.md global + project 或 coding.txt），抽取 sentinel 區塊並去重合併為 skill name list。",
      "decomposition": null
    },
    {
      "id": "A2",
      "title": "Load 技能 Markdown",
      "description": "對 list 內每個 skill name 解析其 SKILL.md 磁碟路徑並讀取內容；若檔案不存在則走 loud-warn fallback（log + anomaly event）而不中斷主流程。",
      "decomposition": null
    },
    {
      "id": "A3",
      "title": "註冊 與 釘選 技能",
      "description": "成功讀取 SKILL.md 的條目 → 呼叫 SkillLayerRegistry.recordLoaded 建立條目、SkillLayerRegistry.pin 鎖定為 sticky 不被 idle-decay。",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Reconcile 已釘選 清單",
      "description": "每輪結尾比對 newList 與目前 registry 已 pinned 項目；對於已從 list 移除者呼叫 unpin、發 skill.mandatory unpinned 事件；對於新增者確保在 A3 處理。",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Inject 技能 Layer Seam",
      "description": "透過既有 skill-layer-seam 機制將 registry 中 active+full 的 skill 內容渲染為 <skill layer> 標籤文本塊，放進 system[] 陣列供 LLM 每輪讀取。",
      "decomposition": null
    }
  ],
