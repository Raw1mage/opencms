{
  "diagram_title": "Gate 自主 Runloop Execution",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "Detect Autorun 啟用 Intent",
      "description": "Receive verbal trigger phrases 或 MCP 問題 answers 與 derive 啟用 signal when preconditions hold",
      "decomposition": null
    },
    {
      "id": "A2",
      "title": "Maintain Session Spec Binding",
      "description": "持久化 與 解析 Session-到-spec-slug mapping that anchors runtime reads 的 規劃 狀態",
      "decomposition": null
    },
    {
      "id": "A3",
      "title": "Gate Runloop 延續",
      "description": "Short-circuit runloop pumping when disarmed; 派發 延續 僅 when 已啟用 與 todos 可執行",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Refill Todolist 來自 規劃",
      "description": "When 已啟用 與 todolist drains, materialize 下一個 tasks.md phase 進入 待辦write 或 end autorun 在 規劃 exhaustion",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "停用 在 Interruption",
      "description": "Flip 已啟用 flag 到 false when 使用者 speaks, blocker fires, 或 abort signal arrives",
      "decomposition": null
    },
    {
      "id": "A6",
      "title": "Demote 規劃 在 Edit",
      "description": "Detect non-checkbox edits 到 bound spec during implementing 與 enforce 狀態 demotion 到 planned plus 停用",
      "decomposition": null
    }
  ],
