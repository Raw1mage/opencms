[
  {
    "id": "S0",
    "label": "閒置",
    "description": "無 待處理 問題; 問題dock unmounted",
    "actions": [],
    "transitions": [
      {
        "to": "S1",
        "condition": "Question.ask called with abort signal",
        "refs": [
          "A1"
        ]
      }
    ]
  },
  {
    "id": "S1",
    "label": "待處理",
    "description": "待處理[id] stored; Bus: 問題.asked published; 問題dock mounted 使用 快取 lookup",
    "actions": [
      "store pending[id] = { info, resolve, reject, dispose }",
      "attach abort handler to signal",
      "Bus.publish(question.asked, info)",
      "QuestionDock: lookup cache[sessionID+hash], restore store if hit"
    ],
    "transitions": [
      {
        "to": "S2",
        "condition": "user submits → /question.reply",
        "refs": [
          "A3"
        ]
      },
      {
        "to": "S3",
        "condition": "user dismisses → /question.reject",
        "refs": [
          "A3"
        ]
      },
      {
        "to": "S4",
        "condition": "stream abort signal fires",
        "refs": [
          "A4",
          "A5"
        ]
      }
    ]
  },
  {
    "id": "S2",
    "label": "Replied",
    "description": "待處理[id] deleted; promise 已解析 使用 answers; Bus: 問題.replied; 問題dock unmounted (快取 cleared 透過 replied=true 路徑)",
    "actions": [
      "delete pending[id]",
      "resolve promise with answers",
      "Bus.publish(question.replied)",
      "dispose abort listener",
      "QuestionDock: clear cache[sessionID+hash]"
    ],
    "transitions": [
      {
        "to": "S0",
        "condition": "always",
        "refs": []
      }
    ]
  },
  {
    "id": "S3",
    "label": "Rejected (manual)",
    "description": "待處理[id] deleted; promise rejected 使用 rejected錯誤; Bus: 問題.rejected; 問題dock unmounted",
    "actions": [
      "delete pending[id]",
      "reject promise with Question.RejectedError",
      "Bus.publish(question.rejected)",
      "dispose abort listener",
      "QuestionDock: clear cache[sessionID+hash]"
    ],
    "transitions": [
      {
        "to": "S0",
        "condition": "always",
        "refs": []
      }
    ]
  },
  {
    "id": "S4",
    "label": "Aborted (串流)",
    "description": "AbortSignal fired; abort handler: delete 待處理 + 發布 rejected + reject promise 使用 rejected錯誤; 問題dock unmounts (在cleanup preserves 快取 供 future AI re-ask)",
    "actions": [
      "delete pending[id]",
      "Bus.publish(question.rejected)",
      "reject promise with Question.RejectedError",
      "log: question aborted, reason=<signal.reason>",
      "QuestionDock.onCleanup: cache[sessionID+hash] = store snapshot (for re-ask restore)"
    ],
    "transitions": [
      {
        "to": "S0",
        "condition": "always",
        "refs": []
      }
    ]
  }
]
