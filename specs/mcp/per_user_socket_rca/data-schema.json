    },
    "transport": "string",
    "urlTemplate": "string",
    "enabled": "boolean",
    "path": "string",
    "source": "string",
    "tools": "array",
    "settingsSchema": "object",
    "modelProcess": "object|null",
    "config": "object"
  },
