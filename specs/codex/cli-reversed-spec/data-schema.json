{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexCliReversedSpecArtifacts",
  "description": "Shapes for chapter content, claim, anchor, and audit-pass evidence.",
  "type": "object",
  "properties": {
    "Chapter": { "$ref": "#/$defs/Chapter" },
    "Claim": { "$ref": "#/$defs/Claim" },
    "CodeAnchor": { "$ref": "#/$defs/CodeAnchor" },
    "AuditPassEvent": { "$ref": "#/$defs/AuditPassEvent" }
  },
  "$defs": {
    "Chapter": {
      "type": "object",
      "properties": {
        "number": { "type": "integer", "minimum": 1, "maximum": 12 },
        "slug": { "type": "string", "pattern": "^[0-9]{2}-[a-z-]+$" },
        "title": { "type": "string" },
        "subsystem_crates": { "type": "array", "items": { "type": "string" } },
        "idef0_path": { "type": "string", "pattern": "^chapters/idef0\\.[0-9]{2}\\.json$" },
        "grafcet_path": { "type": "string", "pattern": "^chapters/grafcet\\.[0-9]{2}\\.json$" },
        "architecture_diagram_kind": { "enum": ["mermaid-block", "mermaid-stack", "mermaid-c4", "ascii-block", "ascii-stack"] },
        "control_mechanism_diagram_present": { "type": "boolean", "description": "true when a separate control/mechanism block diagram is included beyond the IDEF0 ICOM cells (required when any activity lists ≥3 mechanisms)." },
        "protocol_datasheets": {
          "type": "array",
          "description": "Datasheet entries per wire-level message / handshake. Empty array allowed for non-wire-touching chapters; in that case the chapter must include an N/A explanation pointing to the downstream chapter that emits the bytes.",
          "items": { "$ref": "#/$defs/ProtocolDatasheet" }
        },
        "claims": { "type": "array", "items": { "$ref": "#/$defs/Claim" } },
        "open_questions": { "type": "array", "items": { "type": "string" } },
        "opencode_delta_map": { "type": "string", "description": "Markdown body" },
        "status": { "enum": ["draft", "anchored", "audited", "drift-suspect"] }
      },
      "required": ["number", "slug", "title", "claims", "status", "idef0_path", "grafcet_path", "architecture_diagram_kind"]
    },
    "ProtocolDatasheet": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "direction": { "enum": ["client→server", "server→client", "bidirectional"] },
        "transport": { "type": "string", "description": "HTTP METHOD+path / WS frame opcode / SSE event name / on-disk file path" },
        "triggered_by": { "type": "string" },
        "source_anchor": { "type": "string", "description": "file:line of the writer/sender" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type_encoding": { "type": "string" },
              "required": { "type": "boolean" },
              "source": { "type": "string", "description": "file:line where the field is set or parsed" },
              "stability": { "enum": ["stable-per-install", "stable-per-session", "stable-per-turn", "per-turn", "daily-flip", "varies"] },
              "notes": { "type": "string" }
            },
            "required": ["name", "type_encoding", "required", "source", "stability"]
          }
        },
        "example_payload": { "type": "string", "description": "Sanitized example — no real tokens / PII" }
      },
      "required": ["name", "direction", "transport", "source_anchor", "fields", "example_payload"]
    },
    "Claim": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^C[0-9]+$" },
        "text": { "type": "string" },
        "anchor": { "$ref": "#/$defs/CodeAnchor" }
      },
      "required": ["id", "text", "anchor"]
    },
    "CodeAnchor": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "pattern": "^refs/codex/codex-rs/.+" },
        "line": { "type": "integer", "minimum": 1 },
        "symbol": { "type": "string" },
        "kind": { "enum": ["fn", "struct", "enum", "const", "test", "type-alias", "trait", "comment-only"] },
        "excerpt": { "type": "string", "description": "Verbatim N-line snippet that supports the claim." }
      },
      "required": ["path", "kind"]
    },
    "AuditPassEvent": {
      "type": "object",
      "properties": {
        "chapter_number": { "type": "integer" },
        "claim_count": { "type": "integer" },
        "anchor_count": { "type": "integer" },
        "test_or_type_anchor_count": { "type": "integer", "minimum": 1 },
        "submodule_sha": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "open_question_count": { "type": "integer", "minimum": 0 },
        "result": { "enum": ["pass", "fail"] },
        "failures": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["chapter_number", "claim_count", "anchor_count", "test_or_type_anchor_count", "submodule_sha", "result"]
    }
  }
}
