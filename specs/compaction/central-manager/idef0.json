{
  "diagram_title": "Govern Session Compaction Lifecycle",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "Validate Incoming Request",
      "description": "Admit every compaction/enrichment request at the single intake; require and attach origin (call-site id), structured cause (measured signals), and provider class (claude/codex/general); reject malformed requests at the door.",
      "decomposition": null
    },
    {
      "id": "A2",
      "title": "Arbitrate Compaction Trigger",
      "description": "Evaluate reported signals against the central trigger policy (thresholds, priority, 30s cooldown, freerun bypass, subagent rules, provider gates) and decide a single observed condition or a no-op.",
      "decomposition": null
    },
    {
      "id": "A3",
      "title": "Execute Compaction Chain",
      "description": "Run the per-observed kind chain (narrative / ai_free / ai_paid) via the existing run() executor and write the anchor.",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Dispatch Post-Anchor Effects",
      "description": "On a committed anchor, fan out the post-anchor side-effects exactly once: publish chain-reset with the actual kind, and schedule background enrichment at most once per anchor.",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Serialize Session Work",
      "description": "Enforce per-session serialization and anchor-id deduplication so dedup is a structural property of the intake (replaces the retired in-flight guard and the implicit cooldown).",
      "decomposition": null
    },
    {
      "id": "A6",
      "title": "Record Compaction Causes",
      "description": "Append every request's origin, structured cause, and decision to the RCA ledger, and raise first-class anomaly events on policy violations.",
      "decomposition": null
    }
  ],
  "arrows": [
