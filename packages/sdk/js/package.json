{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@opencode-ai/sdk",
  "version": "1.1.65",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "bun run --cwd ../../.. node_modules/.bin/tsgo -p packages/sdk/js/tsconfig.json --noEmit",
    "build": "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/snap/bin bun ./script/build.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./v2": "./src/v2/index.ts",
    "./v2/client": "./src/v2/client.ts",
    "./v2/server": "./src/v2/server.ts"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@hey-api/openapi-ts": "0.90.10",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "dependencies": {},
  "publishConfig": {
    "directory": "dist"
  }
}
